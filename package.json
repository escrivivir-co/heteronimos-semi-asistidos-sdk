{
  "name": "heteronimos-semi-asistidos-sdk",
  "version": "0.0.0",
  "description": "Plugin-based Telegram bot SDK built on grammY",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "bun run ./examples/console-app/main.ts",
    "dev": "bun --watch run ./examples/console-app/main.ts",
    "dev:verbose": "LOG_LEVEL=debug bun --watch run ./examples/console-app/main.ts",
    "dist": "bun dist/main.js",
    "build": "bun build ./examples/console-app/main.ts --outdir ./dist --target node",
    "bot-father-settings": "bun run ./scripts/build-bot-father-settings.ts",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "test:report": "bun test --reporter=junit --reporter-outfile=test-results.xml",
    "test:coverage": "bun test --coverage",
    "release": "bun run ./scripts/release.ts"
  },
  "author": "",
  "license": "AIPL",
  "peerDependencies": {
    "grammy": ">=1.11.0"
  },
  "peerDependenciesMeta": {
    "grammy": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "grammy": "^1.11.2",
    "typescript": "^6.0.2"
  }
}
