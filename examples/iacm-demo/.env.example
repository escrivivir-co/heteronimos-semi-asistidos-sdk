# Tokens de los dos bots de Telegram
# Obtén cada token en @BotFather con /newbot
BOT_TOKEN_METEO=tu_token_meteo_aqui
BOT_TOKEN_DISPATCH=tu_token_dispatch_aqui

# Nombres de los agentes (opcional; se usan en los mensajes IACM)
METEO_AGENT_NAME=MeteoBot
DISPATCH_AGENT_NAME=DispatchBot

# Preferencias del dominio meteorológico (opcional)
DEFAULT_CITY=Madrid
DEFAULT_TIMEZONE=Europe/Madrid

# Rutas de los ficheros de persistencia de chats (opcional)
METEO_STORE_PATH=.meteo-chats.json
DISPATCH_STORE_PATH=.dispatch-chats.json
