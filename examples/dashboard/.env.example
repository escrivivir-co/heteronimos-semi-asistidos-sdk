BOT_TOKEN=your-bot-token
SOLANA_ADDRESS=your-address

# SpiderBot (federation) — optional, defaults shown
OPERATOR_NAME=scriptorium_zero

# HorseBot (IACM) — optional, defaults shown
IACM_AGENT_NAME=scriptorium

# Optional runtime settings
LOG_LEVEL=info

# RabbitBot auto-ack for non-command messages (default: OFF)
RABBIT_AUTO_ACK=0
RABBIT_AUTO_ACK_TEMPLATE=Mensaje recibido de {sender}. Contenido: {size} caracteres. -- RabbitBot · BotHubSDK Scriptorium